# Supabase — find these in your Supabase project dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Service-role key. SERVER-SIDE ONLY. Do NOT prefix with NEXT_PUBLIC_.
# The QPay webhook uses this to bypass RLS when writing donations.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# QPay v2 merchant credentials (from your QPay merchant agreement).
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
# Use https://merchant.qpay.mn/v2 for production, https://merchant-sandbox.qpay.mn/v2 for sandbox.
QPAY_BASE_URL=https://merchant.qpay.mn/v2
# The public HTTPS URL QPay will POST to when an invoice is paid.
# Must be reachable from the internet (Vercel preview/prod URL, ngrok in dev, etc.).
QPAY_CALLBACK_URL=https://your-vercel-deployment.vercel.app/api/qpay/callback
