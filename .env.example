# ─────────────────────────────────────────────────────────────────────────────
# camel_project — environment variables
#
# Copy to `.env` for local dev and fill in real values. `.env` is gitignored;
# this file (`.env.example`) is committed as the canonical list.
#
# For production, set the APP RUNTIME vars (below) in Vercel:
#   Project → Settings → Environment Variables.
# The LOCAL-ONLY vars at the bottom are for the CLI / migrations and must NOT
# be added to Vercel.
# ─────────────────────────────────────────────────────────────────────────────

# ── APP RUNTIME (required in Vercel) ─────────────────────────────────────────

# Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Service-role key. SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_.
# Bypasses RLS; used by the QPay webhook and admin server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP for thank-you emails (nodemailer). Any SMTP provider works.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="ТЭМЭЭ <noreply@your-domain.mn>"

# QPay v2 merchant credentials. Sandbox base URL shown; swap to the production
# base URL when you go live.
QPAY_BASE_URL=https://merchant-sandbox.qpay.mn/v2
QPAY_USERNAME=your-qpay-username
QPAY_PASSWORD=your-qpay-password
QPAY_INVOICE_CODE=your-qpay-invoice-code
# IMPORTANT: must be the FULL public path to the callback route, including /api,
# and point at the stable production domain (not a Vercel preview URL):
#   https://your-domain.mn/api/qpay/callback
QPAY_CALLBACK_URL=https://your-domain.mn/api/qpay/callback

# ── LOCAL ONLY (CLI / migrations — do NOT add to Vercel) ──────────────────────

# Supabase Personal Access Token — for the CLI / Management API.
SUPABASE_PAT=your-supabase-pat
# Database password — for `supabase db` connections.
SUPABASE_DB_PASSWORD=your-db-password
